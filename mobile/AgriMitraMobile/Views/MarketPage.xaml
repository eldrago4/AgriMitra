<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AgriMitraMobile.ViewModels"
    x:Class="AgriMitraMobile.Views.MarketPage"
    x:DataType="vm:MarketViewModel"
    Title="Market Prices"
    BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="0">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="MSP &amp; Market" Style="{StaticResource PageTitle}" />
                    <Label Text="{Binding LastUpdated}" Style="{StaticResource CaptionText}" />
                </VerticalStackLayout>
                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   Color="{StaticResource PrimaryGreen}"
                                   VerticalOptions="Center" />
            </Grid>

            <!-- MSP Table card -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <VerticalStackLayout Spacing="0">
                    <!-- Table header -->
                    <Grid ColumnDefinitions="*,80,60" Padding="0,0,0,8">
                        <Label Grid.Column="0" Text="Crop"
                               Style="{StaticResource CaptionText}" />
                        <Label Grid.Column="1" Text="MSP"
                               Style="{StaticResource CaptionText}" HorizontalOptions="End" />
                        <Label Grid.Column="2" Text="/Unit"
                               Style="{StaticResource CaptionText}" HorizontalOptions="End" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,0,0,8" />

                    <CollectionView ItemsSource="{Binding MspRows}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:MspRow">
                                <VerticalStackLayout Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*,80,60">
                                        <VerticalStackLayout Grid.Column="0">
                                            <Label Text="{Binding Crop}"
                                                   FontSize="14" FontAttributes="Bold"
                                                   TextColor="{StaticResource TextPrimary}" />
                                            <Label Text="{Binding Variety}"
                                                   Style="{StaticResource CaptionText}" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1"
                                               Text="{Binding Price}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{StaticResource PrimaryGreen}"
                                               HorizontalOptions="End"
                                               VerticalOptions="Center" />
                                        <Label Grid.Column="2"
                                               Text="{Binding Unit}"
                                               Style="{StaticResource CaptionText}"
                                               HorizontalOptions="End"
                                               VerticalOptions="Center" />
                                    </Grid>
                                    <!-- Bar chart bar -->
                                    <BoxView HeightRequest="6"
                                             WidthRequest="{Binding BarWidth}"
                                             Color="{StaticResource PrimaryGreenLight}"
                                             CornerRadius="3"
                                             HorizontalOptions="Start"
                                             Margin="0,4,0,0" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Nearest Mandi -->
            <Label Text="Nearest APMC Mandi" Style="{StaticResource SectionHeader}" />

            <Button Text="Find Nearest Mandi (GPS)"
                    Command="{Binding FindNearestMandiCommand}"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,0,12"
                    IsEnabled="{Binding MandiLoading, Converter={StaticResource InvertBool}}" />

            <ActivityIndicator IsRunning="{Binding MandiLoading}"
                               Color="{StaticResource PrimaryGreen}"
                               HorizontalOptions="Center"
                               Margin="0,0,0,12" />

            <!-- Mandi card -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,20"
                    IsVisible="{Binding NearestMandi, Converter={StaticResource NotNull}}">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                    <Label Grid.Row="0" Grid.Column="0"
                           Text="{Binding NearestMandi.Name}"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Border Grid.Row="0" Grid.Column="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="8,4"
                            BackgroundColor="{Binding NearestMandi.IsOpen,
                                Converter={StaticResource BoolToColor},
                                ConverterParameter='#E8F5E9|#FFEBEE'}">
                        <Label Text="{Binding NearestMandi.StatusText}"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{Binding NearestMandi.IsOpen,
                                   Converter={StaticResource BoolToColor},
                                   ConverterParameter='#2D7D32|#D32F2F'}" />
                    </Border>

                    <Label Grid.Row="1" Grid.Column="0"
                           Text="{Binding NearestMandi.District}"
                           Style="{StaticResource BodyText}" />
                    <Label Grid.Row="1" Grid.Column="1"
                           Text="{Binding NearestMandi.Distance}"
                           Style="{StaticResource BodyText}" HorizontalOptions="End" />

                    <Label Grid.Row="2" Grid.ColumnSpan="2"
                           Text="{Binding NearestMandi.Phone}"
                           Style="{StaticResource CaptionText}"
                           Margin="0,6,0,0" />
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
