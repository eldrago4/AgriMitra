<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AgriMitraMobile.ViewModels"
    x:Class="AgriMitraMobile.Views.PredictionResultPage"
    x:DataType="vm:PredictionResultViewModel"
    Title="Prediction Result"
    BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="0">

            <!-- Offline badge -->
            <Border StrokeShape="RoundRectangle 8"
                    BackgroundColor="#FFF3E0" Stroke="Transparent"
                    Padding="12,6" HorizontalOptions="Start" Margin="0,0,0,12"
                    IsVisible="{Binding IsOffline}">
                <Label Text="⚡ Offline prediction" FontSize="12"
                       TextColor="{StaticResource WarningOrange}" />
            </Border>

            <!-- Main yield card -->
            <Border Style="{StaticResource Card}"
                    BackgroundColor="{StaticResource PrimaryGreen}"
                    Margin="0,0,0,16">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding CropType}"
                           TextColor="#CCFFFFFF" FontSize="14" />
                    <Label Text="{Binding YieldText}"
                           TextColor="White" FontSize="42" FontAttributes="Bold" />
                    <Label Text="{Binding UncertaintyText}"
                           TextColor="{StaticResource AccentGold}" FontSize="14" />
                    <BoxView HeightRequest="1" Color="#44FFFFFF" Margin="0,8" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="{Binding ModelVersion}"
                               TextColor="#AAFFFFFF" FontSize="11" />
                        <Label Grid.Column="1" Text="{Binding DateText}"
                               TextColor="#AAFFFFFF" FontSize="11" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Benchmark bar -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="vs. District Average (Sindhudurg)" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" FontSize="14" />
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Your Yield" Style="{StaticResource CaptionText}" />
                        <BoxView HeightRequest="12" WidthRequest="{Binding YieldBarWidth}"
                                 Color="{StaticResource PrimaryGreen}"
                                 CornerRadius="6" HorizontalOptions="Start" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="District Avg" Style="{StaticResource CaptionText}" />
                        <BoxView HeightRequest="12" WidthRequest="{Binding BenchmarkBarWidth}"
                                 Color="#BDBDBD" CornerRadius="6" HorizontalOptions="Start" />
                    </VerticalStackLayout>
                    <Label Text="{Binding BenchmarkText}"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryGreenLight}" />
                </VerticalStackLayout>
            </Border>

            <!-- Advisory cards -->
            <Label Text="Advisories" Style="{StaticResource SectionHeader}" />

            <!-- Fertilizer -->
            <Border Style="{StaticResource AdvisoryCard}"
                    BackgroundColor="#E8F5E9">
                <VerticalStackLayout Spacing="6">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="&#xE5D3;" FontFamily="MaterialIcons"
                               FontSize="20" TextColor="{StaticResource PrimaryGreen}" />
                        <Label Text="Fertilizer Advisory" FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryGreenDark}" FontSize="14" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding FertilizerAdvisory}"
                           Style="{StaticResource BodyText}" />
                </VerticalStackLayout>
            </Border>

            <!-- Irrigation -->
            <Border Style="{StaticResource AdvisoryCard}"
                    BackgroundColor="#E3F2FD">
                <VerticalStackLayout Spacing="6">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="&#xE798;" FontFamily="MaterialIcons"
                               FontSize="20" TextColor="{StaticResource InfoBlue}" />
                        <Label Text="Irrigation Advisory" FontAttributes="Bold"
                               TextColor="#1565C0" FontSize="14" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding IrrigationAdvisory}"
                           Style="{StaticResource BodyText}" />
                </VerticalStackLayout>
            </Border>

            <!-- Market -->
            <Border Style="{StaticResource AdvisoryCard}"
                    BackgroundColor="#FFF8E1">
                <VerticalStackLayout Spacing="6">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="&#xE5D1;" FontFamily="MaterialIcons"
                               FontSize="20" TextColor="{StaticResource AccentGold}" />
                        <Label Text="Market Advisory" FontAttributes="Bold"
                               TextColor="#F57F17" FontSize="14" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding MarketAdvisory}"
                           Style="{StaticResource BodyText}" />
                </VerticalStackLayout>
            </Border>

            <!-- Action buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,20,0,8">
                <Button Grid.Column="0"
                        Text="Share via SMS"
                        Command="{Binding ShareViaSmsCommand}"
                        Style="{StaticResource SecondaryButton}" />
                <Button Grid.Column="1"
                        Text="New Prediction"
                        Command="{Binding NewPredictionCommand}"
                        Style="{StaticResource PrimaryButton}" />
            </Grid>

            <Button Text="View All My Fields"
                    Command="{Binding ViewMyFieldsCommand}"
                    Style="{StaticResource GhostButton}"
                    HorizontalOptions="Center"
                    Margin="0,0,0,16" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
