<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:AgriMitraMobile.Converters"
             x:Class="AgriMitraMobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global converters -->
            <conv:InvertBoolConverter          x:Key="InvertBool" />
            <conv:NotNullConverter             x:Key="NotNull" />
            <conv:BoolToColorConverter         x:Key="BoolToColorConverter"
                                               TrueColor="{StaticResource PrimaryGreen}"
                                               FalseColor="{StaticResource ErrorRed}" />
            <conv:StringToBoolColorConverter   x:Key="BoolToColor" />
            <conv:YieldToBarWidthConverter     x:Key="YieldToBar" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
