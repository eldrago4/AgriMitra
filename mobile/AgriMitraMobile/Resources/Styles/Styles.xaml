<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ── Button Styles ──────────────────────────────────────────── -->

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor"  Value="{StaticResource PrimaryGreen}" />
        <Setter Property="TextColor"        Value="White" />
        <Setter Property="CornerRadius"     Value="10" />
        <Setter Property="FontSize"         Value="16" />
        <Setter Property="FontAttributes"   Value="Bold" />
        <Setter Property="HeightRequest"    Value="52" />
        <Setter Property="Padding"          Value="20,0" />
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor"  Value="Transparent" />
        <Setter Property="TextColor"        Value="{StaticResource PrimaryGreen}" />
        <Setter Property="CornerRadius"     Value="10" />
        <Setter Property="FontSize"         Value="16" />
        <Setter Property="BorderColor"      Value="{StaticResource PrimaryGreen}" />
        <Setter Property="BorderWidth"      Value="2" />
        <Setter Property="HeightRequest"    Value="52" />
    </Style>

    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="BackgroundColor"  Value="Transparent" />
        <Setter Property="TextColor"        Value="{StaticResource PrimaryGreen}" />
        <Setter Property="FontSize"         Value="14" />
        <Setter Property="Padding"          Value="0" />
    </Style>

    <!-- ── Card Style ─────────────────────────────────────────────── -->

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 12" />
        <Setter Property="Stroke"          Value="Transparent" />
        <Setter Property="Padding"         Value="16" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#22000000" Offset="0,2" Radius="8" Opacity="0.15" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Label Styles ───────────────────────────────────────────── -->

    <Style x:Key="PageTitle" TargetType="Label">
        <Setter Property="FontSize"       Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor"      Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="SectionHeader" TargetType="Label">
        <Setter Property="FontSize"       Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor"      Value="{StaticResource TextPrimary}" />
        <Setter Property="Margin"         Value="0,16,0,8" />
    </Style>

    <Style x:Key="BodyText" TargetType="Label">
        <Setter Property="FontSize"  Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style x:Key="CaptionText" TargetType="Label">
        <Setter Property="FontSize"  Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextHint}" />
    </Style>

    <!-- ── Entry Style ────────────────────────────────────────────── -->

    <Style x:Key="InputEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
        <Setter Property="TextColor"       Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextHint}" />
        <Setter Property="FontSize"         Value="15" />
        <Setter Property="HeightRequest"    Value="48" />
        <Setter Property="Margin"           Value="0,4" />
    </Style>

    <!-- ── Pill/Language toggle ───────────────────────────────────── -->

    <Style x:Key="PillUnselected" TargetType="Border">
        <Setter Property="BackgroundColor" Value="White" />
        <Setter Property="Stroke"          Value="{StaticResource PrimaryGreen}" />
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 20" />
        <Setter Property="Padding"         Value="18,8" />
    </Style>

    <Style x:Key="PillSelected" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryGreen}" />
        <Setter Property="Stroke"          Value="{StaticResource PrimaryGreen}" />
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="StrokeShape"     Value="RoundRectangle 20" />
        <Setter Property="Padding"         Value="18,8" />
    </Style>

    <!-- ── Advisory card ──────────────────────────────────────────── -->

    <Style x:Key="AdvisoryCard" TargetType="Border">
        <Setter Property="StrokeShape"     Value="RoundRectangle 10" />
        <Setter Property="Stroke"          Value="Transparent" />
        <Setter Property="Padding"         Value="14" />
        <Setter Property="Margin"          Value="0,6" />
    </Style>

</ResourceDictionary>
